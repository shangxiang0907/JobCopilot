{
  "title": "JobCopilot Overview",
  "uid": "jobcopilot-overview",
  "tags": ["jobcopilot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by service (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (rate(jobcopilot_http_requests_total[5m]))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "5xx error ratio by service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (rate(jobcopilot_http_requests_total{status=~\"5..\"}[5m])) / sum by (job) (rate(jobcopilot_http_requests_total[5m]))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p95 latency by service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, job) (rate(jobcopilot_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Average latency by service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (rate(jobcopilot_http_request_duration_seconds_sum[5m])) / sum by (job) (rate(jobcopilot_http_request_duration_seconds_count[5m]))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Service logs (all containers)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=~\".+\"}"
        }
      ]
    }
  ]
}
