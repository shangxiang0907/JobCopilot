# ─────────────────────────────────────────────────────────────────────────────
# Caddyfile — JobCopilot production edge proxy (Hetzner single-node).
#
# Automatic HTTPS via Let's Encrypt. Caddy obtains and auto-renews certs for the
# apex domain and the `auth.` subdomain, then reverse-proxies over the internal
# Docker network. HTTP is auto-redirected to HTTPS.
#
# Prerequisites:
#   • SERVER_HOST env set to the apex domain (e.g. arnoldshang.com)
#   • DNS A records for both `<SERVER_HOST>` and `auth.<SERVER_HOST>` -> server IP
#   • Cloudflare proxy DISABLED (grey cloud / DNS only) so the ACME HTTP-01
#     challenge reaches Caddy directly on port 80
#   • caddy_data volume mounted so issued certs persist across restarts
# ─────────────────────────────────────────────────────────────────────────────
{
	email admin@{$SERVER_HOST}
}

# Apex domain: Next.js frontend.
# The frontend rewrites /v1/* to Kong internally, so Kong is never exposed here.
{$SERVER_HOST} {
	encode zstd gzip

	header {
		# 1 year HSTS; no includeSubDomains — auth.<host> is served separately.
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	reverse_proxy frontend:3000
}

# Keycloak (OIDC) on the auth subdomain.
# Only the user-facing OIDC surface of the jobcopilot realm is public. The admin
# console/REST API (/admin/*) and the master realm (which admins authenticate
# against) are blocked at the edge, per Keycloak's production hardening guidance —
# administer via SSH tunnel instead:  ssh -L 8080:localhost:8080 <server>
auth.{$SERVER_HOST} {
	encode zstd gzip

	header {
		# Keycloak manages its own CSP/frame headers (login pages may be framed
		# by its own flows) — only add what it does not set itself.
		Strict-Transport-Security "max-age=31536000"
		# Login/registration pages must never appear in search results.
		X-Robots-Tag "noindex, nofollow"
		-Server
	}

	@admin path /admin /admin/* /realms/master /realms/master/*
	respond @admin 403

	reverse_proxy keycloak:8080
}
