{
  "realm": "jobcopilot",
  "enabled": true,
  "displayName": "JobCopilot",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "defaultSignatureAlgorithm": "RS256",
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "offlineSessionMaxLifespanEnabled": false,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "internationalizationEnabled": false,
  "supportedLocales": ["en", "zh-CN"],
  "defaultLocale": "en",
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Platform administrator — full access to all tenants",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "user",
        "description": "Regular authenticated user",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "premium",
        "description": "Premium subscriber with elevated job discovery quota",
        "composite": false,
        "clientRole": false
      }
    ],
    "client": {}
  },
  "defaultRole": {
    "name": "user",
    "description": "Default role assigned to all new users"
  },
  "clients": [
    {
      "clientId": "api",
      "name": "JobCopilot API Resource Server",
      "description": "Bearer-only resource server — validates JWTs issued for the frontend client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": true,
      "serviceAccountsEnabled": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocolMappers": [
        {
          "name": "tenant-id-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "false",
            "user.attribute": "tenant_id",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "tenant_id",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "frontend",
      "name": "JobCopilot Frontend",
      "description": "Public PKCE client for the Next.js SPA",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/*##https://REPLACE_WITH_PRODUCTION_DOMAIN/*"
      },
      "redirectUris": [
        "http://localhost:3000/*",
        "https://REPLACE_WITH_PRODUCTION_DOMAIN/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "https://REPLACE_WITH_PRODUCTION_DOMAIN"
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "tenant-id-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "tenant_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "tenant_id",
            "jsonType.label": "String"
          }
        },
        {
          "name": "audience-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "false",
            "access.token.claim": "true",
            "included.client.audience": "api"
          }
        }
      ]
    }
  ],
  "eventsEnabled": false,
  "eventsExpiration": 0,
  "adminEventsEnabled": false,
  "adminEventsDetailsEnabled": false,
  "smtpServer": {}
}
