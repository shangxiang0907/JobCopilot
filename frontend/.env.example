# Server-side only — read by next.config.ts (build-time rewrite target) and the
# /api/chat proxy route. In Docker this is http://kong:8000.
KONG_URL=http://localhost:8000

# Browser-facing runtime config, served by the dynamic /env.js route as
# window.__ENV__ at REQUEST time (12-factor: same image, per-env values).
# Deliberately NOT NEXT_PUBLIC_* — those are frozen into the bundle at build time.
KEYCLOAK_PUBLIC_URL=http://localhost:8080
KEYCLOAK_REALM=jobcopilot
KEYCLOAK_CLIENT_ID=frontend
