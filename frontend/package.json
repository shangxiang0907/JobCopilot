{
  "name": "jobcopilot-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test:e2e": "playwright test",
    "gen:api-types": "openapi-typescript ../openapi/job.json -o lib/gen/job.ts && openapi-typescript ../openapi/profile.json -o lib/gen/profile.ts && openapi-typescript ../openapi/discovery.json -o lib/gen/discovery.ts && openapi-typescript ../openapi/agent.json -o lib/gen/agent.ts"
  },
  "dependencies": {
    "@assistant-ui/react": "0.14.27",
    "@assistant-ui/react-ai-sdk": "1.3.41",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "ai": "^7.0.31",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "keycloak-js": "^26.2.4",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.7.0",
    "eslint-config-next": "16.2.10",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.20",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2"
  }
}
