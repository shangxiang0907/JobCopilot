# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/jobcopilot

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=jobcopilot

# Profile Service (internal)
PROFILE_SERVICE_URL=http://profile-service:8000

# Playwright — set to false to watch browser during local dev
PLAYWRIGHT_HEADLESS=true

# Security
ENCRYPTION_KEY=<32-byte hex — same key used by Profile Service>

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=jobcopilot
KEYCLOAK_CLIENT_ID=api
