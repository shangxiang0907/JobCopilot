    "/internal/scrape": {
      "post": {
        "description": "Fetch and text-extract a job posting URL for the manual entry path.\n\nNever errors at the HTTP layer \u2014 failures come back as {ok: false, error}\nso the AI assistant can degrade gracefully (prompt the user to paste text).",
        "operationId": "internal_scrape_internal_scrape_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScrapeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Internal Scrape",
        "tags": [
          "internal"
        ]
      }
    },
